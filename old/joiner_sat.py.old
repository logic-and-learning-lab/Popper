def solve_encoding_suboptimal_sat_greedy(self):

        # print('solve_encoding_suboptimal_sat_greedy')

        uncovered = self.state.uncovered.copy()
        fragments = []

        # Build a persistent SAT solver with the time-invariant hard constraints.
        # These never change across outer iterations so we add them once.
        with Solver(name='cadical153') as sat:

            # Negative example hitting set.
            for x_neg in self.neg_index:
                neg_key = -x_neg - 1
                missers = [
                    self.program_selected_var[p]
                    for p in self.programs_not_covering_example[neg_key]
                    if p in self.program_selected_var
                ]
                if missers:
                    sat.add_clause(missers)
                else:
                    return fragments

            # Datalog safety.
            if not self.settings.non_datalog:
                for arg in self.head_args:
                    carriers = [
                        self.program_selected_var[p]
                        for p in self.programs_with_arg[arg]
                        if p in self.program_selected_var
                    ]
                    if carriers:
                        sat.add_clause(carriers)

            # At least two fragments selected.
            card = CardEnc.atleast(
                lits=list(self.program_selected_var.values()),
                bound=2,
                top_id=self.vpool.top,
                encoding=EncType.seqcounter,
            )
            for clause in card.clauses:
                sat.add_clause(clause)
            self.vpool.top = max(self.vpool.top, card.nv)

            while uncovered.any():
                valid_progs = {
                    p for p in self.program_selected_var
                    if (self.pos_exs_covered[p] & uncovered).any()
                }

                if len(valid_progs) < 2:
                    break

                # Try each uncovered example in turn.
                # For each one, ask SAT: is there a valid selection that covers it?
                # If yes, take that solution and update uncovered.
                # If no, skip this example and try the next.
                solved = False
                for e in uncovered.search(1):
                    # Assumption: example e must be covered, i.e. no selected fragment
                    # from valid_progs misses it.  We force this via a unit assumption
                    # on the coverage implication: assume every misser is NOT selected.
                    missers_of_e = [
                        p for p in self.programs_not_covering_example[e]
                        if p in valid_progs
                    ]

                    # Assume all missers of e are deselected.
                    assumptions = [-self.program_selected_var[p] for p in missers_of_e]

                    # Also restrict to valid_progs only by assuming all others deselected.
                    assumptions += [
                        -self.program_selected_var[p]
                        for p in self.program_selected_var
                        if p not in valid_progs
                    ]

                    if not sat.solve(assumptions=assumptions):
                        # Cannot cover example e under current constraints -- skip it.
                        continue


                    # t1 = time.time()
                    model = sat.get_model()
                    # d1 = time.time()-t1
                    selected_ids = [
                        p for p in valid_progs
                        if model[self.program_selected_var[p] - 1] > 0
                    ]

                    # print('inner loop solving time', d1)

                    if not selected_ids:
                        continue

                    pos_covered = bitarray(self.pos_exs_covered[selected_ids[0]].copy())
                    for p_id in selected_ids[1:]:
                        pos_covered &= self.pos_exs_covered[p_id]

                    if not pos_covered.any():
                        assert(False)
                        # continue

                    len_a = len(selected_ids)
                    # t1 = time.time()
                    selected_ids, pos_covered = self.remove_redundant_fragments(selected_ids, pos_covered)
                    # d = time.time()-t1
                    len_b = len(selected_ids)
                    # print(len_a, len_b)

                    pos_covered = frozenbitarray(pos_covered)
                    uncovered &= ~pos_covered
                    unfolded = self.build_unfolded_program(selected_ids)
                    fragments.append([unfolded, pos_covered])

                    if (~pos_covered).any():
                        self.add_consistent_program(pos_covered, calc_prog_size(unfolded))

                    # print('\t greedy1', pos_covered.count(1), calc_prog_size(unfolded))
                    solved = True
                    break

                if not solved:
                    # No uncovered example could be covered -- done.
                    break

        # logger.debug(f"number of fragments found with joiner (sat greedy): {len(fragments)}")
        return fragments


    def solve_sat_newest(self):
        print('')
        print('solve_sat_newest')
        uncovered = self.state.uncovered.copy()
        fragments = []

        while uncovered.any():
            solved = False
            for e in uncovered.search(1):

                print(f'\ttrying {e}')

                # 1. Target R: Find all rules (programs) that cover positive example e
                R = [
                    p for p in self.program_selected_var
                    if self.pos_exs_covered[p][e]
                ]

                # Your constraint requires a subset, and usually "at least 2"
                # to form a conjunction/fragment.
                if len(R) < 2:
                    continue

                with Solver(name='cadical153') as sat:
                    # Constraint: Only pick programs from the set R
                    # (We force all programs NOT in R to be False)
                    for p in self.program_selected_var:
                        if p not in R:
                            sat.add_clause([-self.program_selected_var[p]])

                    # 2. & 3. Handle Negative Examples
                    possible_to_solve_e = True
                    for x_neg in self.neg_index:
                        neg_key = -x_neg - 1

                        # Find rules in R that DO NOT cover this negative example n
                        # These are the "missers"
                        missers_of_n = [
                            self.program_selected_var[p]
                            for p in R
                            if not self.neg_exs_covered[p][neg_key]
                        ]

                        if missers_of_n:
                            # 4. At least one selected rule in S must be a misser of n
                            sat.add_clause(missers_of_n)
                        else:
                            # If no rule in R misses n, then EVERY rule in R covers n.
                            # Therefore, any subset S will also cover n.
                            # This e cannot be solved using rules from R.
                            possible_to_solve_e = False
                            break

                    if not possible_to_solve_e:
                        continue

                    # Additional constraint: S must have at least 2 rules
                    card = CardEnc.atleast(
                        lits=[self.program_selected_var[p] for p in R],
                        bound=2,
                        top_id=self.vpool.top,
                        encoding=EncType.seqcounter,
                    )
                    for clause in card.clauses:
                        sat.add_clause(clause)

                    # Solve
                    if sat.solve():
                        model = sat.get_model()
                        selected_ids = [
                            p for p in R
                            if model[self.program_selected_var[p] - 1] > 0
                        ]

                        # Process the found fragment
                        pos_covered = bitarray(self.pos_exs_covered[selected_ids[0]].copy())
                        for p_id in selected_ids[1:]:
                            pos_covered &= self.pos_exs_covered[p_id]

                        # Clean up and update
                        selected_ids, pos_covered = self.remove_redundant_fragments(selected_ids, pos_covered)
                        pos_covered = frozenbitarray(pos_covered)
                        uncovered &= ~pos_covered

                        unfolded = self.build_unfolded_program(selected_ids)
                        fragments.append([unfolded, pos_covered])

                        solved = True
                        break # Break inner loop to restart with remaining uncovered

            if not solved:
                break # No more examples can be covered

        return fragments

    def solve_sat_newest_(self):
        print('')
        print('solve_sat_newest')
        uncovered = self.state.uncovered.copy()
        fragments = []

        while uncovered.any():

            solved = False
            for e in uncovered.search(1):

                print(f'\ttrying {e}')

                # Filter programs to ONLY those that cover this specific example e
                valid_progs = {
                    p for p in self.program_selected_var
                    if self.pos_exs_covered[p][e]
                }

                # If we don't have at least 2 programs covering e, we can't
                # satisfy the "atleast 2" constraint for this specific e.
                if len(valid_progs) < 2:
                    continue

                # 1. Rebuild the SAT solver instance for the specific example e
                with Solver(name='cadical153') as sat:

                    # --- ADD GLOBAL CONSTRAINTS ---

                    # Negative example hitting set: Ensure consistency
                    sat_feasible = True
                    for x_neg in self.neg_index:
                        missers = [
                            self.program_selected_var[p]
                            for p in self.programs_not_covering_example[x_neg]
                            if p in valid_progs
                        ]
                        if missers:
                            sat.add_clause(missers)
                        else:
                            # Every program in valid_progs covers this negative example.
                            # No solution is possible for example e.
                            sat_feasible = False
                            break

                    if not sat_feasible:
                        continue  # Try the next uncovered positive example e


                    # Datalog safety
                    if not self.settings.non_datalog:
                        for arg in self.head_args:
                            carriers = [
                                self.program_selected_var[p]
                                for p in self.programs_with_arg[arg]
                                if p in valid_progs
                            ]
                            if carriers:
                                sat.add_clause(carriers)

                    # At least two fragments selected
                    card = CardEnc.atleast(
                        lits=list(self.program_selected_var[p] for p in valid_progs),
                        bound=2,
                        top_id=self.vpool.top,
                        encoding=EncType.seqcounter,
                    )
                    for clause in card.clauses:
                        sat.add_clause(clause)
                    # Note: vpool.top management might need care if this loop runs many times
                    # but for a local solver instance, we just need to ensure IDs don't clash.

                    # --- ADD EXAMPLE-SPECIFIC CONSTRAINTS (Replacing Assumptions) ---

                    # Requirement: example e must be covered.
                    # Therefore, any program that MISSES e must NOT be selected.
                    for p in self.programs_not_covering_example[e]:
                        if p in self.program_selected_var:
                            sat.add_clause([-self.program_selected_var[p]])

                    # Restriction: only allow programs in valid_progs
                    for p in self.program_selected_var:
                        if p not in valid_progs:
                            sat.add_clause([-self.program_selected_var[p]])

                    # 2. Solve without assumptions
                    if not sat.solve():
                        print('UNSAT', e)
                        continue
                    else:
                        print('SAT', e)

                    model = sat.get_model()
                    selected_ids = [
                        p for p in valid_progs
                        if model[self.program_selected_var[p] - 1] > 0
                    ]

                    if not selected_ids:
                        continue

                    # --- PROCESS SOLUTION ---
                    pos_covered = bitarray(self.pos_exs_covered[selected_ids[0]].copy())
                    for p_id in selected_ids[1:]:
                        pos_covered &= self.pos_exs_covered[p_id]

                    if not pos_covered.any():
                        # This should technically be impossible given the SAT constraints
                        continue

                    selected_ids, pos_covered = self.remove_redundant_fragments(selected_ids, pos_covered)

                    pos_covered = frozenbitarray(pos_covered)
                    uncovered &= ~pos_covered
                    unfolded = self.build_unfolded_program(selected_ids)
                    fragments.append([unfolded, pos_covered])

                    if (~pos_covered).any():
                        self.add_consistent_program(pos_covered, calc_prog_size(unfolded))

                    solved = True
                    break

            if not solved:
                break

        return fragments
